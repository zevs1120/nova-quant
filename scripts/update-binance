#!/usr/bin/env node
import { spawn } from 'node:child_process';

const args = process.argv.slice(2);
const child = spawn('npx', ['tsx', 'scripts/update-binance.ts', ...args], {
  stdio: 'inherit',
  shell: process.platform === 'win32'
});

child.on('exit', (code) => {
  process.exitCode = code ?? 1;
});
