# Public frontend env for the logged-in user app.

VITE_PUBLIC_SITE_URL=https://novaquant.cloud
VITE_PUBLIC_APP_URL=https://app.novaquant.cloud
VITE_PUBLIC_API_BASE_URL=https://api.novaquant.cloud
VITE_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=https://app.novaquant.cloud/
VITE_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Local development helpers
VITE_API_PROXY_TARGET=http://127.0.0.1:8787

