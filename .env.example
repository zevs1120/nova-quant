# ============================================================
# Nova Quant — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in secrets.
# Loaded by dotenv.config() in src/server/config.ts
# .env is git-ignored. Do NOT commit secrets.

# --- Server ---
PORT=8787

# --- AI Providers ---
# At least one provider is recommended. Without any, Nova falls back to
# deterministic copy instead of LLM-generated responses.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemma-3-27b-it
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=                    # Custom OpenAI-compatible endpoint
# OPENAI_VISION_MODEL=                # Vision model for holdings screenshot import

# --- Nova Cloud LLM (remote fallback) ---
# NOVA_CLOUD_API_KEY=
# NOVA_CLOUD_OPENAI_BASE_URL=
# NOVA_PREFER_CLOUD=0

# --- Local Ollama (auto-detected on localhost, no key needed) ---
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=

# --- Auth: Supabase Postgres (recommended for production) ---
# Set NOVA_AUTH_DRIVER=postgres to enable Postgres-backed auth.
# Connection string priority: NOVA_AUTH_DATABASE_URL > SUPABASE_DB_URL > DATABASE_URL
NOVA_AUTH_DRIVER=postgres
NOVA_AUTH_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# NOVA_AUTH_PG_POOL_MAX=5
# NOVA_AUTH_PG_SSL=require

# --- Auth: Upstash Redis (legacy alternative) ---
# If NOVA_AUTH_DRIVER is not "postgres", the app falls back to Redis-backed
# session store via one of the pairs below.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Seeded Demo User ---
# Creates a default admin user on first boot for local development.
NOVA_ENABLE_SEEDED_DEMO_USER=1
NOVA_SEEDED_DEMO_EMAIL=admin@novaquant.com
NOVA_SEEDED_DEMO_PASSWORD=Admin123
NOVA_SEEDED_DEMO_NAME=Nova Admin
NOVA_SEEDED_DEMO_TRADE_MODE=deep
NOVA_SEEDED_DEMO_BROKER=Other
NOVA_SEEDED_DEMO_LOCALE=zh

# --- Admin ---
NOVA_ADMIN_EMAILS=admin@novaquant.com
NOVA_OWNER_EMAIL=
# NOVA_ADMIN_LIVE_API_BASE=            # Remote admin API for live data
# NOVA_ADMIN_LIVE_API_TOKEN=
# NOVA_ADMIN_REPORT_TIMEZONE=Asia/Shanghai

# --- Model Ingest Token (EC2 → API auth) ---
NOVA_MODEL_INGEST_TOKEN=

# --- CORS (not needed for local dev) ---
# NOVA_APP_ALLOWED_ORIGINS=https://app.novaquant.cloud,https://novaquant.cloud
# NOVA_ADMIN_ALLOWED_ORIGINS=https://admin.novaquant.cloud

# --- Market Search Enhancement ---
# ALPHA_VANTAGE_API_KEY=
# COINGECKO_DEMO_API_KEY=
# COINGECKO_PRO_API_KEY=

# --- News & Financial Data ---
# NEWSAPI_API_KEY=                     # NewsAPI.org headlines
# FINNHUB_API_KEY=                     # Finnhub financial data

# --- Broker / Exchange Connections ---
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# --- Trading Feature Flags (all disabled by default) ---
# NOVA_ENABLE_TRADING=0
# NOVA_ENABLE_LIVE_EXECUTION=0
# NOVA_ENABLE_ORDER_ROUTING=0
# NOVA_ENABLE_ALPACA_TRADING=0
# NOVA_ENABLE_BINANCE_TRADING=0

# --- Execution Governance Kill Switches ---
# NOVA_EXECUTION_KILL_SWITCH_MAX_DRIFT_BPS=
# NOVA_EXECUTION_KILL_SWITCH_MAX_DRIFT_BREACHES=
# NOVA_EXECUTION_KILL_SWITCH_MAX_LOOKUP_FAILURES=
# NOVA_EXECUTION_KILL_SWITCH_MAX_UNRECONCILED=

# --- Password Reset Email (Resend) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Requires a verified Resend sending domain.
# NOVA_AUTH_EMAIL_FROM=Nova Quant <noreply@novaquant.cloud>
# NOVA_AUTH_REPLY_TO=support@novaquant.cloud
# NOVA_APP_URL=https://app.novaquant.cloud

# --- Notifications ---
# DISCORD_WEBHOOK_URL=

# --- Massive.com (formerly Polygon.io) Market Data ---
# Free Basic tier: 5 req/min, 2 years history, EOD data.
# Sign up at https://massive.com to get your API key.
MASSIVE_API_KEY=

# --- Alpha Discovery (EC2 operator) ---
# NOVA_ALPHA_DISCOVERY_ENABLED=
# NOVA_ALPHA_DISCOVERY_INTERVAL_HOURS=
# NOVA_ALPHA_DISCOVERY_MAX_CANDIDATES=
# NOVA_ALPHA_DISCOVERY_SEARCH_BUDGET=
