{
  "buildCommand": "npm run build:api",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:route*",
      "destination": "/api?route=:route*"
    },
    {
      "source": "/healthz",
      "destination": "/api?route=healthz"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
