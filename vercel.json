{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api?route=healthz"
    },
    {
      "source": "/healthz",
      "destination": "/api?route=healthz"
    },
    {
      "source": "/api/:route*",
      "destination": "/api?route=:route*"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
