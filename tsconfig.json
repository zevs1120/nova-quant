{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "outDir": "build-ts"
  },
  "include": ["src/server/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "tests/**/*.d.ts", "api/**/*.ts"]
}
