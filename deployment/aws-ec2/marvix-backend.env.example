# Backend-only Marvix worker on EC2
PORT=8787
SERVE_WEB_DIST=0

# Keep Marvix strategy generation local/deterministic unless a dedicated Marvix inference endpoint is added later.
NOVA_RUNTIME_MODE=deterministic-fallback
NOVA_DISABLE_LOCAL_GENERATION=1
NOVA_DISABLE_GROQ=1

# Gemini handles news factor extraction and plain-language explanation.
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_NEWS_CONCURRENCY=3
GEMINI_NEWS_MIN_REQUEST_GAP_MS=350

# Leave cloud OpenAI-compatible Marvix empty until a self-owned Marvix inference service exists.
NOVA_CLOUD_OPENAI_BASE_URL=
NOVA_CLOUD_API_KEY=
NOVA_CORE_MODEL=
NOVA_SCOUT_MODEL=
NOVA_RETRIEVE_MODEL=
NOVA_CHALLENGER_MODEL=

# Optional hosted providers
GROQ_API_KEY=
OPENAI_API_KEY=

# Market data ingestion
MASSIVE_API_KEY=replace-me

# Model ingest token (EC2 → API auth)
NOVA_MODEL_INGEST_TOKEN=replace-me

# Auth: Supabase Postgres (recommended)
# If NOVA_AUTH_DATABASE_URL is omitted, auth falls back to NOVA_DATA_DATABASE_URL.
NOVA_AUTH_DRIVER=postgres
NOVA_AUTH_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
NOVA_AUTH_PG_SSL=require

# Business data: Supabase Postgres target
NOVA_DATA_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
NOVA_DATA_PG_SCHEMA=novaquant_data
# Postgres is the only supported business runtime.
# Optional hot-path protection after a Postgres timeout.
# NOVA_PG_PRIMARY_READ_FAILURE_COOLDOWN_MS=60000
# NOVA_ALLOW_SYNC_HOT_PATH_FALLBACK=0
# Optional worker warm-start protection: skip heavy startup initialization on already-warm hosts.
# NOVA_AUTO_BACKEND_SKIP_INIT=1

# Auth email delivery
# Resend custom logic has been removed. Configure SMTP delivery inside 
# your Supabase Auth Dashboard using an external provider like AWS SES or Resend SMTP.
NOVA_APP_URL=https://your-domain.com

# Admin access
NOVA_ADMIN_EMAILS=admin@novaquant.com
NOVA_OWNER_EMAIL=

# Public search expansion
ALPHA_VANTAGE_API_KEY=
COINGECKO_DEMO_API_KEY=

# Training/reference data expansion
FINNHUB_API_KEY=
NEWSAPI_API_KEY=

# News and factor throughput
NOVA_NEWS_TTL_MINUTES=30
NOVA_NEWS_CONCURRENCY=6
NOVA_NEWS_MIN_ROWS_FOR_EXPANSION=8
NOVA_NEWS_GOOGLE_LIMIT=8
NOVA_NEWS_HEURISTIC_FACTORS_ENABLED=1

# Autonomous alpha discovery loop
NOVA_ALPHA_DISCOVERY_ENABLED=1
NOVA_ALPHA_DISCOVERY_SCHEDULE=every-4-hours
NOVA_ALPHA_DISCOVERY_INTERVAL_HOURS=4
NOVA_ALPHA_DISCOVERY_MAX_CANDIDATES=64
NOVA_ALPHA_DISCOVERY_SEARCH_BUDGET=36
NOVA_ALPHA_DISCOVERY_MIN_ACCEPTANCE_SCORE=0.64
NOVA_ALPHA_DISCOVERY_MAX_CORRELATION=0.80
NOVA_ALPHA_SHADOW_ADMISSION_MIN_ACCEPTANCE_SCORE=0.56
NOVA_ALPHA_SHADOW_ADMISSION_MAX_DRAWDOWN=0.28
NOVA_ALPHA_SHADOW_MIN_SAMPLE_SIZE=10
NOVA_ALPHA_SHADOW_MIN_SHARPE=0.45
NOVA_ALPHA_SHADOW_MIN_EXPECTANCY=0.0015
NOVA_ALPHA_SHADOW_MAX_DRAWDOWN=0.18
NOVA_ALPHA_SHADOW_MIN_APPROVAL_RATE=0.45
NOVA_ALPHA_RETIRE_MIN_EXPECTANCY=-0.002
NOVA_ALPHA_RETIRE_MAX_DRAWDOWN=0.22
NOVA_ALPHA_RETIRE_DECAY_STREAK_LIMIT=3
NOVA_ALPHA_ALLOW_PROD_PROMOTION=0

# Backend loop cadence
NOVA_AUTO_BACKEND_DERIVE_INTERVAL_SEC=300
NOVA_AUTO_BACKEND_VALIDATE_EVERY=3

# Today action card capacity
NOVA_ACTION_CARD_LIMIT_CONSERVATIVE=10
NOVA_ACTION_CARD_LIMIT_BALANCED=12
NOVA_ACTION_CARD_LIMIT_AGGRESSIVE=15
