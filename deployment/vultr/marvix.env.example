# Standalone Node server
PORT=8787
SERVE_WEB_DIST=1

# Marvix runtime
NOVA_RUNTIME_MODE=cloud-openai-compatible
NOVA_CLOUD_OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
NOVA_CLOUD_API_KEY=replace-me
NOVA_CORE_MODEL=Qwen/Qwen3-8B-Instruct
NOVA_SCOUT_MODEL=Qwen/Qwen3-4B-Instruct
NOVA_RETRIEVE_MODEL=BAAI/bge-m3
NOVA_CHALLENGER_MODEL=Qwen/Qwen3-14B-Instruct

# Optional hosted providers
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Auth: Supabase Postgres
NOVA_AUTH_DRIVER=postgres
NOVA_AUTH_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
NOVA_AUTH_PG_SSL=require
# Required for browser signup/login flows and `/api/auth/provider-config`.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Optional compatibility alias for clients that still read the anon-key name.
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_AUTH_REDIRECT_URL=https://app.novaquant.cloud/

# Business data: Supabase Postgres
NOVA_DATA_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
NOVA_DATA_PG_SCHEMA=novaquant_data

# Auth email delivery
# Resend custom logic has been removed. Configure SMTP delivery inside 
# your Supabase Auth Dashboard using an external provider like AWS SES or Resend SMTP.
NOVA_APP_URL=https://app.novaquant.cloud/

# Public search expansion
ALPHA_VANTAGE_API_KEY=
COINGECKO_DEMO_API_KEY=
