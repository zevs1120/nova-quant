[Unit]
Description=Nova Qlib Bridge (Python Sidecar)
After=network.target marvix-backend.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/nova-quant/qlib-bridge
Environment=HOME=/home/ubuntu
EnvironmentFile=/etc/novaquant/qlib-bridge.env
ExecStart=/home/ubuntu/.local/bin/uv run python -m bridge
Restart=always
RestartSec=10

# Memory limit — prevent OOM on 2GB instance
MemoryMax=1200M
MemoryHigh=900M

[Install]
WantedBy=multi-user.target
