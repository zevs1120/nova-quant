# Nova Qlib Bridge — environment overrides
# Copy to /etc/novaquant/qlib-bridge.env on EC2

QLIB_BRIDGE_HOST=127.0.0.1
QLIB_BRIDGE_PORT=8788
QLIB_BRIDGE_QLIB_PROVIDER_URI=/opt/nova-quant/qlib-bridge/.qlib/qlib_data/us_data
QLIB_BRIDGE_QLIB_REGION=us
QLIB_BRIDGE_NOVA_QUANT_DB=/opt/nova-quant/data/quant.db
QLIB_BRIDGE_MAX_UNIVERSE_SIZE=50
QLIB_BRIDGE_MAX_LOOKBACK_DAYS=750
